{
  "$schema": "./registry.schema.json#/definitions/pipeline",
  "description": "BEO-on-Beads legal delivery/support transitions plus loadable maintenance skills. br owns lifecycle; BEO transitions express execution-safety ownership only.",
  "normal_path": ["beo-plan", "beo-validate", "beo-execute", "beo-review"],
  "owner_classes": {
    "delivery": ["beo-plan", "beo-validate", "beo-execute", "beo-review"],
    "support_runtime": ["beo-debug"],
    "maintenance": ["beo-learn", "beo-author", "beo-setup", "beo-reference"]
  },
  "support_subroutines": {
    "beo-debug": {
      "return_event_kind": "return",
      "return_event_subtype": "debug",
      "callers": ["beo-execute", "beo-review"],
      "return_rule": "Caller resumes only from latest matching debug return. Debug never routes delivery to user directly."
    }
  },
  "post_verdict_hooks": {
    "learning_candidate": {
      "from_owners": ["beo-review", "beo-debug"],
      "to": "beo-learn",
      "authority": "control_plane_only",
      "rule": "Runs only after the source owner has recorded its normal delivery routing, verdict, or support return. It never replaces the delivery exit."
    }
  },
  "virtual_sources": ["start"],
  "transitions": [
    {"from": "start", "condition_id": "bead_selected", "to": "beo-plan", "target_class": "loadable_owner"},
    {"from": "beo-plan", "condition_id": "plan_complete", "to": "beo-validate", "target_class": "loadable_owner"},
    {"from": "beo-plan", "condition_id": "decomposition_recorded", "to": "parent_waits_children", "target_class": "terminal"},
    {"from": "beo-plan", "condition_id": "requirements_missing", "to": "user", "target_class": "terminal"},
    {"from": "beo-plan", "condition_id": "human_gate_blocks", "to": "user", "target_class": "terminal"},
    {"from": "beo-plan", "condition_id": "abandoned", "to": "beo-review", "target_class": "loadable_owner"},
    {"from": "beo-validate", "condition_id": "PASS_EXECUTE", "to": "beo-execute", "target_class": "loadable_owner"},
    {"from": "beo-validate", "condition_id": "FAIL_PLAN", "to": "beo-plan", "target_class": "loadable_owner"},
    {"from": "beo-validate", "condition_id": "BLOCK_USER", "to": "user", "target_class": "terminal"},
    {"from": "beo-validate", "condition_id": "abandoned", "to": "beo-review", "target_class": "loadable_owner"},
    {"from": "beo-execute", "condition_id": "execution_ready_for_review", "to": "beo-review", "target_class": "loadable_owner"},
    {"from": "beo-execute", "condition_id": "approval_stale_or_invalid", "to": "beo-validate", "target_class": "loadable_owner"},
    {"from": "beo-execute", "condition_id": "scope_delta_required", "to": "beo-plan", "target_class": "loadable_owner"},
    {"from": "beo-execute", "condition_id": "blocker_found", "to": "beo-debug", "target_class": "support_runtime"},
    {"from": "beo-execute", "condition_id": "user_blocker", "to": "user", "target_class": "terminal"},
    {"from": "beo-execute", "condition_id": "abandoned", "to": "beo-review", "target_class": "loadable_owner"},
    {"from": "beo-review", "condition_id": "entry_blocked_execution_evidence_incomplete", "to": "beo-execute", "target_class": "loadable_owner"},
    {"from": "beo-review", "condition_id": "verdict_accept", "to": "done", "target_class": "terminal"},
    {"from": "beo-review", "condition_id": "repair_same_scope", "to": "beo-validate", "target_class": "loadable_owner"},
    {"from": "beo-review", "condition_id": "repair_rescope", "to": "beo-plan", "target_class": "loadable_owner"},
    {"from": "beo-review", "condition_id": "cannot_deliver", "to": "user", "target_class": "terminal"},
    {"from": "beo-review", "condition_id": "root_cause_diagnosis_needed", "to": "beo-debug", "target_class": "support_runtime"},
    {"from": "beo-review", "condition_id": "repair_budget_exceeded", "to": "user", "target_class": "terminal"},
    {"from": "beo-review", "condition_id": "abandoned", "to": "done", "target_class": "terminal"},
    {"from": "beo-debug", "condition_id": "debug_returned", "to": "subroutine_done", "target_class": "terminal"},
    {"from": "beo-debug", "condition_id": "debug_abandoned", "to": "subroutine_done", "target_class": "terminal"},

    {"from": "beo-learn", "condition_id": "case_recorded", "to": "done", "target_class": "terminal"},
    {"from": "beo-learn", "condition_id": "authoring_requested", "to": "beo-author", "target_class": "maintenance"},
    {"from": "beo-learn", "condition_id": "insufficient_evidence", "to": "user", "target_class": "terminal"},
    {"from": "beo-author", "condition_id": "skill_authored_or_updated", "to": "done", "target_class": "terminal"},
    {"from": "beo-author", "condition_id": "reference_or_registry_updated", "to": "done", "target_class": "terminal"},
    {"from": "beo-author", "condition_id": "no_change_needed", "to": "done", "target_class": "terminal"},
    {"from": "beo-author", "condition_id": "user_review_needed", "to": "user", "target_class": "terminal"},
    {"from": "beo-setup", "condition_id": "setup_complete", "to": "done", "target_class": "terminal"},
    {"from": "beo-setup", "condition_id": "user_confirmation_needed", "to": "user", "target_class": "terminal"}
  ],
  "invalid_transitions": [
    {"from": "beo-plan", "condition_id": "any", "to": "beo-execute", "reason": "beo-validate must grant PASS_EXECUTE"},
    {"from": "beo-review", "condition_id": "repair_same_scope", "to": "beo-execute", "reason": "same-scope repair still requires approval refresh"},
    {"from": "beo-debug", "condition_id": "any", "to": "user", "reason": "debug is a subroutine; caller decides user routing"}
  ]
}
