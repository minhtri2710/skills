{
  "$schema": "./registry.schema.json#/definitions/artifact-schemas",
  "shared_shapes": {
    "human_gate_shape": {
      "status": "resolved | unresolved | not_applicable",
      "gates": [
        {
          "id": "HG-1",
          "type": "clarification | choice | authorization | secret | execution_preview",
          "question": "<human-facing decision>",
          "affects": [
            "scope",
            "acceptance",
            "non_goals",
            "compatibility",
            "security",
            "privacy",
            "access",
            "legal",
            "business",
            "approval",
            "user_visible_commitment"
          ],
          "resolution_status": "resolved | unresolved",
          "resolution_ref": "<artifact section | user message ref | env:HANDLE>",
          "notes": "<optional, no secrets>"
        }
      ]
    },
    "verification_evidence_item": {
      "required": [
        "command",
        "status",
        "evidence_ref"
      ],
      "command": "<verification command from verification_contract.commands>",
      "status": "passed | failed | skipped",
      "evidence_ref": "<command output, log, or run reference>",
      "skip_rule": "skipped is valid only for verification_contract optional_commands or not_applicable_commands; required commands must have passed evidence"
    },
    "transition_provenance_shape": {
      "required": [
        "from_owner",
        "condition_id",
        "to_owner",
        "feature_slug",
        "artifact_root",
        "created_at",
        "basis_ref"
      ],
      "optional": [
        "artifact_hash_ref",
        "return"
      ],
      "return_required_when_meta_target": [
        "meta_target",
        "return_target_owner",
        "return_condition_id",
        "return_basis_required"
      ],
      "rule": "from_owner, condition_id, and to_owner must match registry/pipeline.json; feature_slug and artifact_root must match current artifact authority."
    },
    "closure_shape": {
      "required": [
        "status",
        "closed_at",
        "closed_by_owner"
      ],
      "status": "closed | repair_requested | abandoned",
      "optional": [
        "reason_ref",
        "verdict_ref",
        "learning_ref"
      ],
      "abandoned_rule": "status abandoned requires lifecycle_status abandoned; the owner emitting legal user_abandoned -> done may write only abandonment lifecycle bookkeeping, and no product mutation occurs as part of abandonment."
    },
    "debug_diagnosis_shape": {
      "required": [
        "id",
        "feature_slug",
        "created_by_owner",
        "created_at",
        "assigned_question",
        "diagnosis_status",
        "evidence_refs",
        "recommended_next_owner"
      ],
      "diagnosis_status": "root_cause_proven | inconclusive | user_owned",
      "return_rule": "root_cause_proven may target return_to_caller only when transition.return provenance is fresh and legal."
    }
  },
  "artifact_densities": {
    "compact": {
      "artifact_set": [
        "FEATURE.json",
        "HANDOFF.json",
        "TICKET.md"
      ],
      "authority_blocks": [
        "yaml beo.ticket"
      ],
      "phase_sections": {
        "explore": {
          "owner": "beo-explore",
          "required_after_owner_exit": [
            "artifact_density",
            "ticket_id",
            "title",
            "lifecycle_status",
            "phase_status",
            "current_owner",
            "request",
            "done",
            "human_gates"
          ],
          "optional": [
            "assumptions",
            "non_goals",
            "constraints"
          ]
        },
        "plan": {
          "owner": "beo-plan",
          "required_after_owner_exit": [
            "scope.files.allow",
            "scope.files.forbid",
            "scope.item",
            "scope.verify",
            "acceptance_criteria"
          ],
          "derived_approval_projection": {
            "declared_files": "scope.files.allow",
            "forbidden_paths": "scope.files.forbid",
            "generated_outputs": "not_applicable unless specified",
            "non_goal_constraints": "non_goals or [] when absent",
            "risk_scope": "not_applicable unless specified",
            "rollback_boundary": "not_applicable unless specified",
            "execution_sets": [
              {
                "id": "set-1",
                "items": [
                  {
                    "id": "item-1",
                    "description": "scope.item"
                  }
                ],
                "kind": "normal",
                "files": "scope.files.allow"
              }
            ],
            "acceptance_criteria": "acceptance_criteria",
            "verification_contract": "scope.verify"
          }
        },
        "approval": {
          "owner": "beo-validate",
          "required_for_PASS_EXECUTE": [
            "readiness",
            "approval_ref",
            "integrity",
            "selected_execution_set",
            "execution_mode"
          ],
          "required_for_failure_readiness": [
            "readiness",
            "readiness_reason"
          ]
        },
        "execution": {
          "owner": "beo-execute",
          "required_for_ready_for_review": [
            "execution_status",
            "pre_execution_integrity_check",
            "changed_files",
            "verification_evidence",
            "review_status",
            "blocker"
          ]
        },
        "review": {
          "owner": "beo-review",
          "required_after_terminal_review": [
            "verdict",
            "review_evidence",
            "findings",
            "closure"
          ],
          "optional": [
            "learning_candidate"
          ]
        }
      },
      "field_ownership": {
        "beo-explore": [
          "artifact_density",
          "ticket_id",
          "title",
          "created_from_request",
          "lifecycle_status",
          "phase_status",
          "current_owner",
          "owner",
          "request",
          "done",
          "human_gates",
          "assumptions",
          "non_goals",
          "constraints"
        ],
        "beo-plan": [
          "phase_status",
          "current_owner",
          "owner",
          "scope",
          "acceptance_criteria",
          "generated_outputs",
          "risk_scope",
          "rollback_boundary"
        ],
        "beo-validate": [
          "phase_status",
          "current_owner",
          "owner",
          "readiness",
          "readiness_reason",
          "selected_execution_set",
          "execution_mode",
          "approval_ref",
          "integrity"
        ],
        "beo-execute": [
          "phase_status",
          "current_owner",
          "owner",
          "execution_status",
          "pre_execution_integrity_check",
          "changed_files",
          "verification_evidence",
          "review_status",
          "blocker",
          "execution_notes"
        ],
        "beo-review": [
          "phase_status",
          "current_owner",
          "owner",
          "verdict",
          "findings",
          "review_evidence",
          "closure",
          "learning_candidate",
          "lifecycle_status"
        ],
        "beo-route": [
          "phase_status",
          "current_owner",
          "owner"
        ]
      },
      "identity_consistency": "compact current_owner is owner-bearing authority; optional owner mirror must match current_owner when present. FEATURE.json.current_owner, STATE, and HANDOFF are advisory mirrors handled by references/state.md; stale mirrors require beo-route repair but do not override compact authority. Meta-targets require transition provenance.",
      "future_owned_fields": "absent until owning phase acts; examples may use comments only",
      "handoff_identity_update": "Each outgoing owner may update phase_status/current_owner/owner only while emitting one legal transition and matching transition provenance; beo-route may update identity mirrors only after proving an identity defect."
    },
    "full": {
      "artifact_set": [
        "FEATURE.json",
        "CONTEXT.md",
        "PLAN.md",
        "TRACKER.json",
        "REVIEW.md",
        "HANDOFF.json"
      ],
      "authority_blocks": [
        "yaml beo.context",
        "yaml beo.plan",
        "yaml beo.review_decision"
      ],
      "phase_sections": {
        "explore": {
          "owner": "beo-explore",
          "artifact": "CONTEXT.md",
          "required_after_owner_exit": [
            "artifact_density",
            "owner",
            "request",
            "done",
            "human_gates"
          ],
          "optional": [
            "assumptions",
            "non_goals",
            "constraints"
          ]
        },
        "plan": {
          "owner": "beo-plan",
          "artifact": "PLAN.md",
          "required_after_owner_exit": [
            "declared_files",
            "forbidden_paths",
            "generated_outputs",
            "non_goal_constraints",
            "risk_scope",
            "rollback_boundary",
            "execution_sets",
            "acceptance_criteria",
            "verification_contract"
          ]
        },
        "approval": {
          "owner": "beo-validate",
          "artifact": "PLAN.md#Approval",
          "required_for_PASS_EXECUTE": [
            "readiness",
            "approval_ref",
            "integrity",
            "selected_execution_set",
            "execution_mode"
          ]
        },
        "execution": {
          "owner": "beo-execute",
          "artifact": "TRACKER.json",
          "required_for_ready_for_review": [
            "feature_slug",
            "artifact_root",
            "approval_ref_id",
            "ledger_status",
            "pre_execution_integrity_check",
            "selected_execution_set",
            "execution_mode",
            "items",
            "changed_files",
            "observations",
            "blockers",
            "scope_delta_requests",
            "repair_budget",
            "resume_point",
            "rollback_status"
          ]
        },
        "review": {
          "owner": "beo-review",
          "artifact": "REVIEW.md",
          "required_after_terminal_review": [
            "verdict",
            "review_evidence",
            "findings",
            "closure"
          ],
          "optional": [
            "learning_candidate"
          ]
        }
      }
    }
  },
  "manifest_schema": {
    "file": "FEATURE.json",
    "required": [
      "feature_slug",
      "artifact_root",
      "artifact_density",
      "lifecycle_status",
      "current_owner",
      "created_at",
      "updated_at",
      "artifacts"
    ],
    "canonical_artifact_root": ".beads/artifacts/<feature_slug>",
    "mixed_density_policy": "fail_closed"
  },
  "ledger_schema": {
    "file": "TRACKER.json",
    "required": [
      "feature_slug",
      "artifact_root",
      "approval_ref_id",
      "selected_execution_set",
      "execution_mode",
      "ledger_status",
      "pre_execution_integrity_check",
      "items",
      "changed_files",
      "observations",
      "blockers",
      "scope_delta_requests",
      "repair_budget",
      "resume_point",
      "rollback_status"
    ]
  },
  "handoff_schema": {
    "file": "HANDOFF.json",
    "required": [
      "feature_slug",
      "artifact_root",
      "from_owner",
      "to_owner",
      "condition_id",
      "created_at",
      "required_reads",
      "transition"
    ],
    "transition_rule": "Top-level feature_slug, artifact_root, from_owner, to_owner, condition_id, and created_at must match HANDOFF.transition; contradictions fail closed."
  },
  "debug_diagnosis_schema": {
    "artifact_target": "feature artifact root DEBUG_DIAGNOSIS.md or debug-diagnosis-<id>.json",
    "required": [
      "id",
      "feature_slug",
      "created_by_owner",
      "created_at",
      "assigned_question",
      "diagnosis_status",
      "evidence_refs",
      "recommended_next_owner"
    ],
    "shared_shape_ref": "shared_shapes.debug_diagnosis_shape",
    "return_rule": "recommended_next_owner return_to_caller requires transition.return provenance and diagnosis_status root_cause_proven."
  },
  "learning_case_schema": {
    "required": [
      "id",
      "case_status",
      "case_type",
      "feature_slug",
      "source",
      "observed_case",
      "affected_owner",
      "runtime_status",
      "created_at"
    ],
    "vocabulary_ref": "learning-vocabulary.json"
  },
  "learning_pattern_schema": {
    "required": [
      "id",
      "pattern_status",
      "supporting_case_ids",
      "recurring_issue",
      "affected_surfaces",
      "authoring_recommendation",
      "created_at"
    ],
    "vocabulary_ref": "learning-vocabulary.json"
  },
  "execution_set_schema": {
    "kind": [
      "normal",
      "repair",
      "rollback"
    ],
    "repair_constraint": "execution_set.files must be a subset of declared_files",
    "rollback_constraint": "rollback execution sets require rollback_from_execution_set"
  },
  "pre_execution_integrity_check_schema": {
    "required": [
      "helper",
      "evidence_ref",
      "approval_envelope_status"
    ],
    "approval_envelope_status": [
      "complete",
      "invalid",
      "unavailable"
    ]
  }
}
