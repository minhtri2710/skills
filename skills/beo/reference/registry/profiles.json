{
  "$schema": "./registry.schema.json#/definitions/profile-registry",
  "description": "BEO-on-Beads mode/profile registry. Profiles are authoring shorthand only; helpers expand them into approval-bearing projection fields before hashing.",
  "modes": {
    "quick": {
      "artifact_set": ["TICKET.md", "checks/*.json"],
      "requires": ["one atomic bead", "repo-only change", "small declared file set", "no generated-output complexity", "no external side effect", "simple revert rollback"],
      "forbids": ["strict side effects", "stateful external system mutation", "parent bead execution", "multi-task execution"],
      "operator_path": "compact plan authoring is allowed only after br show and claim; beo-validate, beo-execute, and beo-review remain separate gates"
    },
    "standard": {
      "artifact_set": ["TICKET.md", "checks/*.json"],
      "requires": ["one atomic bead", "declared generated outputs when present", "explicit verification", "explicit risk and rollback when quick posture is insufficient"],
      "forbids": ["deployment", "database migration", "cloud resource mutation", "payment/cost mutation", "package publication", "email/message send"]
    },
    "strict": {
      "artifact_set": ["TICKET.md", "STRICT.md", "ROLLBACK.md", "checks/*.json"],
      "requires": ["explicit Human Gate authorization", "named external/stateful target", "rollback or compensation plan", "strict artifact hashes", "strict side-effect command contract", "review evidence"],
      "forbids": ["quick posture shorthand", "implicit side effects", "uncontracted side-effect commands"]
    }
  },
  "reservation_policy": {
    "canonical_authority": "profiles.json",
    "default": "conflict_check_only",
    "require_current_reservation_when": [
      "mode_is_strict",
      "parallel_execution_risk_declared",
      "active_overlap_or_concurrency_risk_detected",
      "broad_scope_authorized_by_human_gate"
    ],
    "modes": {
      "quick": {
        "default_current_reservation": false,
        "require_when": ["active_overlap_or_concurrency_risk_detected", "parallel_execution_risk_declared", "broad_scope_authorized_by_human_gate"]
      },
      "standard": {
        "default_current_reservation": false,
        "require_when": ["active_overlap_or_concurrency_risk_detected", "parallel_execution_risk_declared", "broad_scope_authorized_by_human_gate"]
      },
      "strict": {
        "default_current_reservation": true,
        "require_when": ["always"]
      }
    }
  },
  "independence_policy": {
    "quick": {
      "same_actor_allowed": true,
      "reason": "low-risk repo-only work"
    },
    "standard": {
      "same_actor_allowed": true,
      "review_requires_independent_diff_inspection": true
    },
    "strict": {
      "same_actor_allowed": "false_by_default",
      "requires": ["separate_validate_or_review_actor", "explicit_human_override"]
    }
  },
  "repair_budget_policy": {
    "description": "Maximum repair attempts per mode before repair_budget_exceeded terminal route.",
    "quick": {
      "budget": 1,
      "reason": "quick mode is for simple low-risk changes; one repair attempt is sufficient"
    },
    "standard": {
      "budget": 2,
      "reason": "standard mode allows moderate complexity; two repair attempts balance convergence and cost"
    },
    "strict": {
      "budget": "explicit",
      "reason": "strict mode requires explicit repair budget in ticket or authorization gate; default is human confirmation per repair"
    },
    "counter_rule": "Repair counter increments on each repair route from beo-review (repair_same_scope, repair_rescope). Counter resets only on new PASS_EXECUTE after user-driven plan restart or issue reassignment.",
    "terminal_route": "repair_budget_exceeded routes to user with current repair count and mode budget for explicit continuation or cannot_deliver decision."
  },
  "flow_profiles": {
    "tiny_repo_edit": {
      "mode": "quick",
      "requires": ["one bounded execution item", "scope.files.allow", "scope.verify.commands", "acceptance_criteria"],
      "derives": {
        "selected_execution_set": "set-1",
        "execution_mode": "normal"
      },
      "forbids": ["multiple execution items", "repair execution set", "rollback execution set"]
    },
    "standard_repo_edit": {
      "mode": "standard",
      "requires": ["scope.files.allow", "scope.verify.commands", "acceptance_criteria", "risk_scope", "rollback_boundary"],
      "derives": {
        "selected_execution_set": "set-1",
        "execution_mode": "normal"
      },
      "forbids": ["external side effects", "stateful external system mutation"]
    },
    "strict_external": {
      "mode": "strict",
      "requires": ["strict.reason", "authorization_refs", "risk_scope", "rollback_boundary", "strict.artifact_hashes", "strict side-effect profile fields"],
      "derives": {
        "selected_execution_set": "set-1",
        "execution_mode": "strict"
      }
    }
  },
  "posture_profiles": {
    "repo_only_low_risk": {
      "valid_modes": ["quick", "standard"],
      "expands": {
        "generated_outputs": [],
        "external_side_effects": {"status": "none", "effects": []},
        "stateful_external_systems": {"status": "none", "systems": []},
        "risk_scope": "low: bounded edits to declared repo files only",
        "rollback_boundary": "revert_declared_file_changes"
      },
      "forbids": ["generated output complexity", "external side effect", "stateful external system mutation", "uncertain rollback"]
    }
  },
  "protected_path_defaults": [
    ".git/**",
    ".env",
    ".env.*",
    "**/.env",
    "**/.env.*",
    "secrets/**",
    "credentials/**",
    "*.pem",
    "*.key",
    "*.p12",
    "*.pfx",
    "id_rsa",
    "id_ed25519",
    ".beads/beads.db"
  ],
  "side_effect_command_patterns": [
    "deploy",
    "migration",
    "migrate",
    "publish",
    "email",
    "payment",
    "billing",
    "terraform apply",
    "kubectl apply",
    "cloud resource",
    "third-party write"
  ]
}
