{
  "$schema": "./registry.schema.json#/definitions/memory-backends",
  "description": "BEO memory backend registry. Memory is advisory and never grants approval, execution permission, or review verdicts.",
  "backends": {
    "obsidian_cli": {
      "kind": "preferred_write_backend",
      "config": {
        "vault_env": "BEO_OBSIDIAN_VAULT",
        "vault_cli_target_env": ["BEO_OBSIDIAN_VAULT_ID", "BEO_OBSIDIAN_VAULT_NAME"],
        "learning_subdir": "beo-learnings",
        "required_for_delivery": false,
        "requires_cli_enabled": true,
        "requires_obsidian_running": true
      },
      "writes_allowed_by": ["beo-learn"],
      "reads_allowed_by": ["beo-recall", "beo-learn", "beo-author"],
      "fallback": "local_markdown",
      "secret_rule": "handles_only",
      "authority": "advisory_memory_only",
      "write_boundary": {
        "allowed_subdir": "beo-learnings",
        "markdown_only": true,
        "reject_path_traversal": true,
        "reject_symlink_escape": true,
        "reject_plugins_config_attachments": true
      }
    },
    "qmd": {
      "kind": "search_index",
      "required_for_delivery": false,
      "query_allowed_by": ["beo-recall", "beo-learn", "beo-author"],
      "status_allowed_by": ["beo-setup", "beo-recall", "beo-learn", "beo-author"],
      "get_allowed_by": ["beo-recall", "beo-learn", "beo-author"],
      "index_update_allowed_by": ["beo-setup", "beo-learn"],
      "collection_add_allowed_by": ["beo-setup", "beo-learn"],
      "collection_add_mask": "**/*.md",
      "index_write_kind": "write_memory_index",
      "index_update_operation": "memory_index_maintenance",
      "auto_index_allowed_after_learning_write": true,
      "delivery_setup_auto_index_allowed": false,
      "explicit_user_authorization_required_for_setup_index_update": true,
      "failure_blocks_learning": false
    },
    "local_markdown": {
      "kind": "fallback",
      "required_for_learning": true,
      "paths": [
        ".beads/artifacts/<issue-id>/learning/<note-name>.md"
      ]
    }
  },
  "rules": [
    "Memory is advisory only.",
    "Learning must be durable even if Obsidian CLI or qmd is unavailable.",
    "Recall must be read-only.",
    "No memory backend may grant PASS_EXECUTE or review verdicts.",
    "No memory backend may mutate product files."
  ]
}
