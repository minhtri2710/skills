{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "registry.schema.json",
  "title": "BEO Registry Schema",
  "description": "Meta-schema for all BEO registry files. Each registry file must match its corresponding definition.",
  "definitions": {
    "core-vocabulary": {
      "type": "object",
      "required": [
        "runtime_owners",
        "owner_classes",
        "utilities",
        "terminal_targets",
        "meta_targets",
        "artifact_density",
        "readiness",
        "execution_mode",
        "review_status",
        "verdict",
        "integrity_status",
        "field_status",
        "human_gate_type",
        "human_gate_affects",
        "human_gate_status",
        "lifecycle_status",
        "ledger_status",
        "item_status",
        "execution_set_kind",
        "rollback_boundary",
        "proof_status",
        "debug_unblock_class",
        "command_authority",
        "command_contract_status",
        "approval_envelope_status"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "runtime_owners": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "owner_classes": {
          "type": "object",
          "required": [
            "runtime_delivery",
            "runtime_support",
            "utility",
            "maintenance"
          ],
          "properties": {
            "runtime_delivery": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "runtime_support": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "utility": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "maintenance": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        },
        "utilities": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "terminal_targets": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "meta_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "readiness": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "execution_mode": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "review_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "verdict": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "field_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "route_defect_types": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_gate_type": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_gate_affects": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "human_gate_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "rollback_boundary": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "proof_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "debug_unblock_class": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "command_authority": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "command_contract_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "approval_envelope_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "style_forbidden_aliases": {
          "type": "object",
          "additionalProperties": {
            "type": "string"
          }
        },
        "lifecycle_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "ledger_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "item_status": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "execution_set_kind": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "artifact_density": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "integrity_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "vocabulary": {
      "$ref": "#/definitions/core-vocabulary"
    },
    "learning-vocabulary": {
      "type": "object",
      "required": [
        "learning_case_status",
        "learning_pattern_status",
        "learning_case_types",
        "learning_runtime_status"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "learning_case_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "learning_pattern_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "learning_case_types": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "learning_runtime_status": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        }
      }
    },
    "approval-envelope": {
      "type": "object",
      "required": [
        "approval_projection_rule",
        "required_fields"
      ],
      "properties": {
        "app_rule": {
          "type": "string"
        },
        "approval_projection_rule": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "compact_input_rule": {
          "type": "string"
        },
        "required_fields": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "id"
            ],
            "properties": {
              "id": {
                "type": "string"
              },
              "owner": {
                "type": "string"
              },
              "standard_source": {
                "type": "string"
              },
              "compact_source": {
                "type": "string"
              },
              "full_source": {
                "type": "string"
              }
            }
          }
        },
        "approval_ref_schema": {
          "type": "object"
        }
      }
    },
    "artifact-schemas": {
      "type": "object",
      "required": [
        "artifact_densities"
      ],
      "properties": {
        "$schema": {
          "type": "string"
        },
        "shared_shapes": {
          "type": "object"
        },
        "artifact_densities": {
          "type": "object",
          "required": [
            "compact",
            "full"
          ],
          "properties": {
            "compact": {
              "type": "object",
              "required": [
                "artifact_set",
                "phase_sections"
              ],
              "properties": {
                "artifact_set": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "authority_blocks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "phase_sections": {
                  "type": "object",
                  "required": [
                    "explore",
                    "plan",
                    "approval",
                    "execution",
                    "review"
                  ],
                  "properties": {
                    "explore": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "plan": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "approval": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "execution": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "review": {
                      "$ref": "#/definitions/phase-section"
                    }
                  }
                }
              }
            },
            "full": {
              "type": "object",
              "required": [
                "artifact_set",
                "phase_sections"
              ],
              "properties": {
                "artifact_set": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "authority_blocks": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "phase_sections": {
                  "type": "object",
                  "required": [
                    "explore",
                    "plan",
                    "approval",
                    "execution",
                    "review"
                  ],
                  "properties": {
                    "explore": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "plan": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "approval": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "execution": {
                      "$ref": "#/definitions/phase-section"
                    },
                    "review": {
                      "$ref": "#/definitions/phase-section"
                    }
                  }
                }
              }
            }
          }
        },
        "manifest_schema": {
          "$ref": "#/definitions/named-artifact-schema"
        },
        "ledger_schema": {
          "$ref": "#/definitions/named-artifact-schema"
        },
        "handoff_schema": {
          "$ref": "#/definitions/named-artifact-schema"
        },
        "debug_diagnosis_schema": {
          "$ref": "#/definitions/versioned-artifact-schema"
        },
        "learning_case_schema": {
          "$ref": "#/definitions/versioned-artifact-schema"
        },
        "learning_pattern_schema": {
          "$ref": "#/definitions/versioned-artifact-schema"
        },
        "execution_set_schema": {
          "type": "object"
        },
        "pre_execution_integrity_check_schema": {
          "type": "object"
        }
      },
      "additionalProperties": false
    },
    "named-artifact-schema": {
      "type": "object",
      "required": [
        "file",
        "schema_version",
        "required"
      ],
      "properties": {
        "file": {
          "type": "string"
        },
        "schema_version": {
          "type": "string"
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "canonical_artifact_root": {
          "type": "string"
        },
        "mixed_density_policy": {
          "type": "string"
        }
      }
    },
    "versioned-artifact-schema": {
      "type": "object",
      "required": [
        "required"
      ],
      "properties": {
        "schema_version": {
          "type": "string"
        },
        "required": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "approval_impact": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "scope_policy": {
          "type": "string"
        },
        "vocabulary_ref": {
          "type": "string"
        }
      }
    },
    "command-contracts": {
      "type": "object",
      "required": [
        "commands"
      ],
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "command_id",
              "command",
              "binary",
              "argv_templates",
              "contract_status",
              "authority_level",
              "allowed_callers",
              "allowed_stages",
              "reads",
              "writes",
              "output_format"
            ],
            "properties": {
              "command_id": {
                "type": "string"
              },
              "command": {
                "type": "string"
              },
              "binary": {
                "type": "string"
              },
              "argv_templates": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                },
                "minItems": 1
              },
              "contract_status": {
                "type": "string",
                "enum": [
                  "unavailable",
                  "contracted"
                ]
              },
              "authority_level": {
                "type": "string"
              },
              "allowed_callers": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "allowed_stages": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "reads": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "writes": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "output_format": {
                "type": "string"
              },
              "required_output_fields": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "may_grant_approval": {
                "type": "boolean"
              },
              "may_refresh_approval": {
                "type": "boolean"
              },
              "may_mutate_product_files": {
                "type": "boolean"
              },
              "may_select_execution_set": {
                "type": "boolean"
              },
              "may_mutate_workflow_artifacts": {
                "type": "boolean"
              },
              "failure_handling": {
                "type": "string"
              },
              "forbidden_interpretations": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              }
            }
          }
        }
      }
    },
    "helper-output-schema": {
      "type": "object",
      "required": [
        "fields"
      ],
      "properties": {
        "fields": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "required": [
              "required"
            ],
            "properties": {
              "required": {
                "type": "boolean"
              },
              "allowed_values_ref": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "pipeline": {
      "type": "object",
      "required": [
        "normal_path",
        "virtual_sources",
        "transitions",
        "invalid_transitions"
      ],
      "properties": {
        "description": {
          "type": "string"
        },
        "normal_path": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "minItems": 1
        },
        "virtual_sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "condition_id",
              "to",
              "target_class"
            ],
            "properties": {
              "from": {
                "type": "string"
              },
              "condition_id": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "target_class": {
                "type": "string",
                "enum": [
                  "runtime_owner",
                  "utility",
                  "terminal",
                  "meta"
                ]
              },
              "handoff_required": {
                "type": "boolean"
              }
            }
          }
        },
        "invalid_transitions": {
          "type": "array",
          "items": {
            "type": "object",
            "required": [
              "from",
              "condition_id",
              "to",
              "reason"
            ],
            "properties": {
              "from": {
                "type": "string"
              },
              "condition_id": {
                "type": "string"
              },
              "to": {
                "type": "string"
              },
              "reason": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "phase-section": {
      "type": "object",
      "required": [
        "owner"
      ],
      "properties": {
        "owner": {
          "type": "string"
        },
        "artifact": {
          "type": "string"
        },
        "required_after_owner_exit": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_for_PASS_EXECUTE": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_for_ready_for_review": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "required_after_terminal_review": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "derived_approval_projection": {
          "type": "object"
        }
      },
      "additionalProperties": false
    }
  }
}
