{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "BEO TICKET.json version 1",
  "description": "BEO TICKET.json version 1. Owns request, done criteria, approved scope, verification commands, and risk/strict contracts. Does not own br lifecycle, approval state, execution state, review verdict, runtime events, or learning notes.",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "issue_id", "mode", "request", "done_criteria", "scope"],
  "$defs": {
    "safe_path": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!.*[\\x00-\\x1F])(?![/\\\\])(?!.:)(?!\\.([/\\\\])?$)(?!.*(^|[/\\\\])\\.\\.([/\\\\]|$))\\S(?:.*\\S)?$"
    }
  },
  "properties": {
    "version": { "const": 1 },
    "issue_id": { "type": "string", "minLength": 1 },
    "mode": { "enum": ["quick", "standard", "strict"] },
    "fast_track": { "type": "boolean", "default": false },
    "request": { "type": "string", "minLength": 1 },
    "done_criteria": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["files", "generated_outputs", "verify"],
      "properties": {
        "files": {
          "type": "object",
          "additionalProperties": false,
          "required": ["allow", "forbid"],
          "properties": {
            "allow": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/safe_path" } },
            "forbid": { "type": "array", "items": { "$ref": "#/$defs/safe_path" } }
          }
        },
        "generated_outputs": { "type": "array", "items": { "$ref": "#/$defs/safe_path" } },
        "verify": {
          "type": "object",
          "additionalProperties": false,
          "required": ["commands"],
          "properties": {
            "commands": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1,
                "description": "Each verify command is exec'd directly via execve (shell=False, no shell). Pipes, redirects, &&, ||, ;, and env-var expansion are NOT supported. For multi-step commands, list them as separate items."
              }
            }
          }
        }
      }
    },
    "risk": {
      "type": "object",
      "additionalProperties": false,
      "required": ["summary", "rollback"],
      "properties": {
        "summary": { "type": "string", "minLength": 1 },
        "rollback": { "type": "string", "minLength": 1 }
      }
    },
    "human_gates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["status", "gates"],
      "properties": {
        "status": { "enum": ["resolved", "unresolved", "not_applicable"] },
        "gates": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "scope", "approver_handle", "valid_for_issue_id", "reason"],
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "scope": { "type": "string", "minLength": 1 },
              "approver_handle": { "type": "string", "minLength": 1 },
              "valid_for_issue_id": { "type": "string", "minLength": 1 },
              "reason": { "type": "string", "minLength": 1 },
              "revocation_ref": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "strict": {
      "type": "object",
      "additionalProperties": false,
      "required": ["reason", "authorization_refs", "rollback_refs", "external_side_effects", "stateful_external_systems"],
      "properties": {
        "reason": { "type": "string", "minLength": 1 },
        "authorization_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "worktree_isolation": { "type": "boolean", "default": false },
        "rollback_refs": { "type": "array", "minItems": 1, "items": { "type": "string", "minLength": 1 } },
        "external_side_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["type", "target", "authorization_ref", "precheck", "rollback_or_compensation", "postcheck", "blast_radius"],
            "properties": {
              "type": { "type": "string", "minLength": 1 },
              "target": { "type": "string", "minLength": 1 },
              "authorization_ref": { "type": "string", "minLength": 1 },
              "precheck": { "type": "string", "minLength": 1 },
              "rollback_or_compensation": { "type": "string", "minLength": 1 },
              "postcheck": { "type": "string", "minLength": 1 },
              "blast_radius": { "type": "string", "minLength": 1 }
            }
          }
        },
        "stateful_external_systems": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["name", "effect_ref"],
            "properties": {
              "name": { "type": "string", "minLength": 1 },
              "effect_ref": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "human_gates": {
            "properties": { "status": { "const": "resolved" } },
            "required": ["status"]
          }
        },
        "required": ["human_gates"]
      },
      "then": {
        "properties": {
          "human_gates": {
            "properties": { "gates": { "minItems": 1 } }
          }
        }
      }
    },
    {
      "if": { "properties": { "mode": { "const": "quick" } } },
      "then": {
        "not": { "anyOf": [ { "required": ["risk"] }, { "required": ["strict"] } ] },
        "if": { "properties": { "fast_track": { "const": true } }, "required": ["fast_track"] },
        "then": {
          "properties": {
            "scope": {
              "properties": {
                "files": {
                  "properties": {
                    "allow": {
                      "description": "Fast track requires explicit file paths, no globs",
                      "items": {
                        "allOf": [
                          { "$ref": "#/$defs/safe_path" },
                          { "not": { "pattern": "[\\*\\?]" } }
                        ]
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    {
      "if": { "properties": { "mode": { "const": "standard" } } },
      "then": { "required": ["risk"], "not": { "required": ["strict"] } }
    },
    {
      "if": { "properties": { "mode": { "const": "strict" } } },
      "then": {
        "required": ["risk", "human_gates", "strict"],
        "properties": {
          "human_gates": {
            "properties": {
              "status": { "const": "resolved" },
              "gates": { "minItems": 1 }
            }
          }
        }
      }
    }
  ]
}
